# Copy this file to .env and set a real password before running
# `docker compose up`. .env is gitignored — it never gets committed.

ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# From Cloudflare Zero Trust > Networks > Tunnels > (your tunnel) > Configure
# — use the token from the "Docker" install command, not the whole command.
CLOUDFLARE_TUNNEL_TOKEN=change-me
